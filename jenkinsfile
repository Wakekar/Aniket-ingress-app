pipeline {
    agent any

    environment {
        DOCKER_HUB_REPO = 'Aniket/techsolutions-app'
        APP_NAME = 'techsolutions'
    }

    stages {

        stage('Pre-checks') {
            steps {
                echo 'Checking Docker and Kubernetes access...'
                sh 'docker --version'
                sh 'kubectl get nodes'
            }
        }

        stage('Install Java & Maven (if needed)') {
            steps {
                echo 'Installing Java & Maven (safe to run even if already installed)...'
                sh '''
                sudo apt-get update -y
                sudo apt-get install -y openjdk-17-jdk maven || true
                java -version || true
                mvn -version || true
                '''
            }
        }

        stage('Checkout') {
            steps {
                echo 'Cloning repository...'
                git 'https://github.com/Wakekar/Aniket-ingress-app.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    def tag = "${env.BUILD_NUMBER}"
                    env.IMAGE_TAG = tag

                    sh "docker build -t ${DOCKER_HUB_REPO}:${tag} ."
                    sh "docker tag ${DOCKER_HUB_REPO}:${tag} ${DOCKER_HUB_REPO}:latest"
                }
            }
        }

        stage('Push to DockerHub') {
            steps {
                script {
                    withCredentials([usernamePassword(credentialsId: 'dockerhub-creds', usernameVariable: 'USER', passwordVariable: 'PASS')]) {
                        sh "echo $PASS | docker login -u $USER --password-stdin"
                        sh "docker push ${DOCKER_HUB_REPO}:${env.IMAGE_TAG}"
                        sh "docker push ${DOCKER_HUB_REPO}:latest"
                    }
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                script {
                    echo 'Updating image version in deployment...'

                    sh """
                    sed -i 's|Aniketj/techsolutions-app:latest|Aniketj/techsolutions-app:${IMAGE_TAG}|g' k8s/Aniketdeployment.yaml
                    """

                    sh "kubectl apply -f k8s/Aniketdeployment.yaml"
                    sh "kubectl rollout status deployment/${APP_NAME}-deployment --timeout=300s"
                }
            }
        }

        stage('Deploy Ingress') {
            steps {
                sh "kubectl apply -f k8s/AniketIngress.yaml"
            }
        }

        stage('Verify Deployment') {
            steps {
                echo 'Verifying deployment...'
                sh "kubectl get pods -o wide"
                sh "kubectl get svc"
                sh "kubectl get ingress"
            }
        }
    }

    post {
        always {
            echo 'Cleaning up local Docker images...'
            sh "docker rmi ${DOCKER_HUB_REPO}:${IMAGE_TAG} || true"
            sh "docker rmi ${DOCKER_HUB_REPO}:latest || true"
        }

        success {
            echo '✅ Deployment Successful!'
        }

        failure {
            echo '❌ Pipeline Failed! Check logs carefully.'
        }
    }
}
